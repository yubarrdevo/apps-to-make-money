# LiteLLM Environment Variables

# Master key for admin access to LiteLLM
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-9c2d72b2b8e61d402b7316fed0276e675117cd4a1342fa572c84e7e20223c0b6

# Database connection (PostgreSQL)
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://litellm:YOUR_DB_PASSWORD_HERE@litellm-db:5432/litellm

# Note: This is a simplified CPU-only setup
# Only uses Ollama models running on host (systemd service)
# No GPU models (vLLM removed)
