# LiteLLM Configuration
# Copy this to ~/income-services/litellm/.env and fill in the values

# Database password (must match POSTGRES_PASSWORD below)
# Generate with: openssl rand -hex 16
LITELLM_DB_PASSWORD=YOUR_DB_PASSWORD
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# LiteLLM master key — used by all admin API calls
# Generate with: openssl rand -hex 32  (prefix with sk-)
LITELLM_MASTER_KEY=sk-YOUR_MASTER_KEY_HERE

# Full connection string (built from the values above)
DATABASE_URL=postgresql://litellm:YOUR_DB_PASSWORD@litellm-db:5432/litellm
