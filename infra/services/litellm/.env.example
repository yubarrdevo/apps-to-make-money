# LiteLLM Environment Variables

# Master key for admin access to LiteLLM
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=CHANGE_ME

# Database password for PostgreSQL
# Generate with: openssl rand -hex 16
LITELLM_DB_PASSWORD=CHANGE_ME

# Note: This is a simplified CPU-only setup
# Only uses Ollama models running on host (systemd service)
# No GPU models (vLLM removed)
