# ComfyUI Configuration
# No secrets needed - ComfyUI runs without authentication by default
# Access at http://localhost:8188 or https://studio.atividata.com.br

# GPU Memory (0.0-1.0, 0.9 recommended for RTX 3060 12GB)
GPU_MEMORY=0.9

# Models will be stored in ./models/
# Download models to:
#   - ./models/checkpoints/    (Stable Diffusion, FLUX models)
#   - ./models/vae/            (VAE models)
#   - ./models/loras/          (LoRA models)
#   - ./models/controlnet/     (ControlNet models)
